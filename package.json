{
  "name": "json-schema-mui-config-demo",
  "private": true,
  "version": "0.1.0",
  "license": "LGPL-3.0-or-later",
  "type": "module",
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "pnpm typecheck && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/roboto": "5.2.10",
    "@iarna/toml": "^2.2.5",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@noble/curves": "^2.2.0",
    "@rjsf/core": "6.4.2",
    "@rjsf/mui": "6.4.2",
    "@rjsf/utils": "6.4.2",
    "@rjsf/validator-ajv8": "6.4.2",
    "json5": "^2.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.9",
    "vitest": "^4.1.8"
  }
}
